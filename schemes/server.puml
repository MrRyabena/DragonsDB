@startuml
hide empty members
skinparam classAttributeIconSize 0

package core {
  class Defaults <<final>> {
    +{static} STORAGE_PATH : String
    +{static} CHARSET : Charset
    +{static} SERVER_HOST : String
    +{static} SERVER_PORT : int
    +{static} DB_HOST : String
    +{static} DB_PORT : int
    +{static} DB_NAME : String
    +{static} RESPONSE_TIMEOUT : int
  }

  class Coordinates {
    -x : Float
    -y : Float
    +Coordinates(x: Float, y: Float)
    +getX() : Float
    +getY() : Float
    +setXY(x: Float, y: Float) : void
  }

  class Request <<Serializable>> {
    enum Status {INIT, COMMAND, PARAMETER_RESPONSE, GET_SCRIPT}
    +status : Status
    +command : String
    +parameterValue : String
    +sessionId : long
    +login : String
    +password : String
    +{static} command(text: String, login: String, password: String) : Request
    +{static} parameterResponse(sessionId: long, value: String, login: String, password: String) : Request
  }

  class Response <<Serializable>> {
    enum Status {SUCCESS, ERROR, NEED_PARAMETER, NEED_PASSWORD}
    +status : Status
    +data : List<Dragon>
    +message : String
    +parameterRequest : ParameterRequest
    +sessionId : long
    +{static} success(dragons: List, msg: String) : Response
    +{static} error(msg: String) : Response
    +{static} needParameter(sessionId: long, param: ParameterRequest) : Response
    +{static} needPassword(sessionId: long, param: ParameterRequest) : Response
  }

  class ParameterRequest <<Serializable>> {
    enum ParameterType {STRING, INTEGER, LONG, FLOAT, DRAGON_TYPE, DRAGON, ID}
    +parameterName : String
    +prompt : String
    +type : ParameterType
    +required : boolean
    +ParameterRequest(name, prompt, type, required)
  }

  class WireFrame <<final>> {
    +{static} MAGIC : int
    +{static} VERSION : short
    +{static} MAX_PACKET_SIZE : int
    +requestId : long
    +sessionId : long
    +flags : byte
    +payload : byte[]
    +toBytes() : byte[]
    +{static} fromBytes(raw: byte[], length: int) : WireFrame
    +{static} wrapRequest(request: Request, requestId: long) : WireFrame
    +{static} wrapResponse(response: Response, requestId: long) : WireFrame
    +unwrapRequest() : Request
    +unwrapResponse() : Response
  }
}

package dragon {
  enum DragonType {
    WATER
    UNDERGROUND
    AIR
    FIRE
  }

  class DragonHead {
    -size : float
    -toothCount : float
    +DragonHead(size: float, toothCount: float)
    +getSize() : float
    +getToothCount() : float
  }

  class Dragon {
    -id : Long
    -name : String
    -coordinates : Coordinates
    -creationDate : LocalDateTime
    -age : int
    -weight : long
    -speaking : boolean
    -type : DragonType
    -head : DragonHead
    +Dragon(name: String, coordinates: Coordinates, age: int, weight: long, type: DragonType, head: DragonHead)
    +Dragon(name: String, coordinates: Coordinates, age: int, weight: long)
    +getId() : long
    +getName() : String
    +getCoordinates() : Coordinates
    +getCreationDate() : LocalDateTime
    +getAge() : int
    +getWeight() : long
    +isSpeaking() : boolean
    +getType() : DragonType
    +getHead() : DragonHead
    +compareTo(other: Dragon) : int
  }
}

package "dragon.view" {
  interface View {
    +toView(stream: Stream<Dragon>) : InputStream
    +fromView(stream: OutputStream) : Stream<Dragon>
  }

  class JsonView {
    -gson : Gson
    +toView(stream: Stream<Dragon>) : InputStream
    +fromView(stream: OutputStream) : Stream<Dragon>
  }
}

package collection {
  interface API {
    +add(element: Dragon) : void
    +add(elements: Stream<Dragon>) : void
    +updateById(element: Dragon) : void
    +clear() : void
    +getStream() : Stream<Dragon>
    +removeIf(filter: Predicate<Dragon>) : void
    +countIf(filter: Predicate<Dragon>) : int
  }

  class Collection {
    -buffer : HashSet<Dragon>
    +Collection()
    +Collection(buffer: Set<Dragon>)
    +Collection(stream: Stream<Dragon>)
    +add(element: Dragon) : void
    +add(elements: Stream<Dragon>) : void
    +updateById(element: Dragon) : void
    +getStream() : Stream<Dragon>
    +removeIf(filter: Predicate<Dragon>) : void
    +countIf(filter: Predicate<Dragon>) : int
    +clear() : void
    +getBuffer() : Set<Dragon>
  }

  class DatabaseCollection extends Collection {
    +DatabaseCollection()
    +add(element: Dragon, ownerLogin: String) : void
    +updateById(element: Dragon, ownerLogin: String) : void
    +clear(ownerLogin: String) : int
    +removeIf(filter: Predicate<Dragon>, ownerLogin: String) : int
    +removeById(id: long, ownerLogin: String) : void
  }
}

package storage {
  interface Storage {
    +save(stream: InputStream) : void
    +load() : OutputStream
    +getDateCreated() : Date
    +getDateModified() : Date
  }

  class DatabaseStorage {
    +DatabaseStorage()
    +save(stream: InputStream) : void
    +load() : OutputStream
    +getDateCreated() : Date
    +getDateModified() : Date
  }

  interface CommandLogger {
    +logCommand(txnId: long, command: ApiCommand, dragonData: String) : long
    +commitCommand(logId: long) : void
    +rollbackCommand(logId: long) : void
    +commitTransaction(transactionId: long) : void
    +rollbackTransaction(transactionId: long) : void
    +getTransactionLogs(transactionId: long) : List<CommandLog>
    +getPendingLogsForRecovery() : List<CommandLog>
    +clearLog() : void
    +generateTransactionId() : long
  }

  class FileCommandLogger {
    +FileCommandLogger(storagePath: String)
    +logCommand(txnId: long, command: ApiCommand, dragonData: String) : long
    +commitCommand(logId: long) : void
    +rollbackCommand(logId: long) : void
    +commitTransaction(transactionId: long) : void
    +rollbackTransaction(transactionId: long) : void
    +getTransactionLogs(transactionId: long) : List<CommandLog>
    +getPendingLogsForRecovery() : List<CommandLog>
    +clearLog() : void
    +generateTransactionId() : long
  }

  class TransactionManager {
    -currentTxnId : long
    +TransactionManager(commandLogger: CommandLogger)
    +beginTransaction() : long
    +getCurrentTransactionId() : long
  }

  class RecoveryManager {
    +RecoveryManager(commandLogger: CommandLogger, collection: API)
    +performRecovery() : int
  }

  class PostgresSupport <<final>> {
    +{static} DEFAULT_URL : String
    +{static} DEFAULT_DRAGON_TABLE : String
    +{static} openConnection() : Connection
    +{static} ensureDragonSchema(connection: Connection) : void
  }

  class PostgresDragonRepository <<final>> {
    +{static} loadAll() : List<Dragon>
    +{static} insert(dragon: Dragon, ownerLogin: String) : Dragon
    +{static} update(dragon: Dragon, ownerLogin: String) : void
    +{static} deleteById(id: long) : void
    +{static} deleteById(id: long, ownerLogin: String) : void
    +{static} deleteByIds(ids: List<long>) : void
    +{static} deleteByIds(ids: List<long>, ownerLogin: String) : void
    +{static} clear() : void
    +{static} clear(ownerLogin: String) : int
    +{static} findOwnedIds(ids: List<long>, ownerLogin: String) : Set<long>
    +{static} getDateCreated() : Date
    +{static} getDateModified() : Date
  }
}

package server {
  class Server {
    +{static} main(args: String[]) : void
  }

  class ConnectionHandler <<AutoCloseable>> {
    +ConnectionHandler()
    +ConnectionHandler(port: int)
    +get() : Optional<ServerContext>
    +getChannel() : DatagramChannel
    +close() : void
  }

  class RequestReader <<Consumer>> {
    +RequestReader()
    +accept(context: ServerContext) : void
  }

  class ResponseSender <<Consumer>> {
    +ResponseSender(channel: DatagramChannel)
    +accept(context: ServerContext) : void
  }

  class ResponsePacker <<Consumer>> {
    +ResponsePacker()
    +accept(context: ServerContext) : void
  }

  class ServerContext {
    +clientAddress : SocketAddress
    +requestData : ByteBuffer
    +request : Request
    +response : Response
    +responseData : ByteBuffer
    +requestId : long
    +sessionId : long
    +skipCommandHandling : boolean
  }

  class AuthService {
    +register(login: String, rawPassword: String) : boolean
    +authenticate(login: String, rawPassword: String) : boolean
    +validateCredentials(login: String, rawPassword: String) : void
  }

  class AuthenticationHandler <<Consumer>> {
    +AuthenticationHandler(sessionManager: SessionManager, authService: AuthService)
    +accept(context: ServerContext) : void
  }

  class CommandsHandler <<Consumer>> {
    +CommandsHandler(collection, storage, commandLogger, transactionManager, sessionManager)
    +handleRequest(context: ServerContext) : void
  }

  class ClientRequestHandler <<Runnable>> {
    +ClientRequestHandler(context, reader, authHandler, commandsHandler, packer, sender)
    +run() : void
  }

  class ClientSession {
    enum AuthAction {NONE, LOGIN, REGISTER}
    -sessionId : long
    -clientAddress : SocketAddress
    -currentCommand : Commands
    -pendingParameters : Queue<ParameterRequest>
    -collectedParameters : Map<String, Object>
    -authAction : AuthAction
    -authenticatedLogin : String
    +ClientSession(clientAddress: SocketAddress)
    +getSessionId() : long
    +getCurrentCommand() : Commands
    +setCurrentCommand(command: Commands) : void
    +peekNextParameter() : ParameterRequest
    +pollNextParameter() : ParameterRequest
    +addParameterRequest(param) : void
    +addParameter(name, value) : void
    +hasMoreParameters() : boolean
    +clearDialog() : void
    +startAuthDialog(action: AuthAction) : void
    +isAuthDialogActive() : boolean
    +getAuthAction() : AuthAction
    +clearAuthDialog() : void
    +getAuthenticatedLogin() : String
    +setAuthenticatedLogin(authenticatedLogin: String) : void
  }

  class SessionManager {
    -sessions : Map<SocketAddress, ClientSession>
    -cleanupTimer : Timer
    +SessionManager()
    +getOrCreateSession(address: SocketAddress) : ClientSession
    +getSession(address: SocketAddress) : ClientSession
    +removeSession(address: SocketAddress) : void
    +getAllSessions() : Collection<ClientSession>
    +shutdown() : void
  }
}

' --- Relationships ---
"dragon.Dragon" *-- "core.Coordinates"
"dragon.Dragon" *-- "dragon.DragonHead"
"dragon.Dragon" o-- "dragon.DragonType"

"collection.Collection" ..|> "collection.API"
"collection.DatabaseCollection" --|> "collection.Collection"
"storage.DatabaseStorage" ..|> "storage.Storage"
"storage.FileCommandLogger" ..|> "storage.CommandLogger"
"dragon.view.JsonView" ..|> "dragon.view.View"

"core.Response" --> "core.ParameterRequest"
"core.Response" --> "dragon.Dragon"
"core.WireFrame" --> "core.Request"
"core.WireFrame" --> "core.Response"

"server.Server" --> "storage.DatabaseStorage"
"server.Server" --> "collection.DatabaseCollection"
"server.Server" --> "storage.FileCommandLogger"
"server.Server" --> "storage.TransactionManager"
"server.Server" --> "storage.RecoveryManager"
"server.Server" --> "server.AuthService"
"server.Server" --> "server.AuthenticationHandler"
"server.Server" --> "server.ClientRequestHandler"
"server.Server" --> "server.ConnectionHandler"
"server.Server" --> "server.RequestReader"
"server.Server" --> "server.CommandsHandler"
"server.Server" --> "server.ResponsePacker"
"server.Server" --> "server.ResponseSender"
"server.Server" --> "server.SessionManager"

"server.ConnectionHandler" --> "server.ServerContext"
"server.RequestReader" --> "server.ServerContext"
"server.RequestReader" --> "core.Request"
"server.RequestReader" --> "core.WireFrame"
"server.AuthenticationHandler" --> "server.ServerContext"
"server.AuthenticationHandler" --> "server.SessionManager"
"server.AuthenticationHandler" --> "server.ClientSession"
"server.AuthenticationHandler" --> "server.AuthService"
"server.AuthenticationHandler" --> "core.Request"
"server.AuthenticationHandler" --> "core.Response"
"server.AuthenticationHandler" --> "core.ParameterRequest"
"server.ResponsePacker" --> "server.ServerContext"
"server.ResponsePacker" --> "core.Response"
"server.ResponsePacker" --> "core.WireFrame"
"server.ResponseSender" --> "server.ServerContext"

"server.ClientRequestHandler" --> "server.ServerContext"
"server.ClientRequestHandler" --> "server.RequestReader"
"server.ClientRequestHandler" --> "server.AuthenticationHandler"
"server.ClientRequestHandler" --> "server.CommandsHandler"
"server.ClientRequestHandler" --> "server.ResponsePacker"
"server.ClientRequestHandler" --> "server.ResponseSender"

"server.CommandsHandler" --> "server.ServerContext"
"server.CommandsHandler" --> "server.SessionManager"
"server.CommandsHandler" --> "server.ClientSession"
"server.CommandsHandler" --> "core.ParameterRequest"
"server.CommandsHandler" --> "collection.DatabaseCollection"
"server.CommandsHandler" --> "collection.API"
"server.CommandsHandler" --> "storage.DatabaseStorage"
"server.CommandsHandler" --> "storage.CommandLogger"
"server.CommandsHandler" --> "storage.TransactionManager"
"server.CommandsHandler" --> "core.Request"
"server.CommandsHandler" --> "core.Response"

"server.SessionManager" --> "server.ClientSession"
"server.ClientSession" --> "core.ParameterRequest"

"storage.TransactionManager" --> "storage.CommandLogger"
"storage.RecoveryManager" --> "storage.CommandLogger"
"storage.RecoveryManager" --> "collection.API"
"storage.DatabaseStorage" --> "storage.PostgresDragonRepository"
"storage.DatabaseStorage" --> "dragon.view.JsonView"
"storage.PostgresDragonRepository" --> "storage.PostgresSupport"
"server.AuthService" --> "storage.PostgresSupport"

@enduml